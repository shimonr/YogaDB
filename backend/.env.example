# Copy this file to backend/.env and edit values for your machine.
# Paths below are examples — use absolute paths after moving the project.

APP_NAME=Yoga DB API
ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite file is created in backend/ when uvicorn runs from backend/
DATABASE_URL=sqlite:///./yogadb.db

# Comma-separated frontend origins
CORS_ORIGINS=http://localhost:5173

# Asana inventory CSV (same file used by yoga-image-collector)
ASANAS_CSV_PATH=C:/path/to/yoga-image-collector/input/yoga_asanas.csv

# Root folder of per-asana image subfolders (same path used with init_db.py --images-dir)
ASANAS_IMAGES_DIR=C:/path/to/yoga-image-collector/asana_images
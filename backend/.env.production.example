# Production environment variables for Render deployment.
# Copy this to backend/.env for local testing against a production-style config.

# --- Required ---
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/yogadb
SECRET_KEY=<generate a random hex string>

# --- Cloudinary (for image storage) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- CORS (set to your Vercel frontend URL) ---
CORS_ORIGINS=https://your-app.vercel.app

# --- App ---
ENV=production
DEBUG=false
